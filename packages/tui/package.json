{
	"name": "@hansjm10/volt-tui",
	"version": "0.1.0",
	"description": "Terminal User Interface library with differential rendering for efficient text-based applications",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"test": "node --test test/*.test.ts",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"files": [
		"dist/**/*",
		"native/win32/prebuilds/**/*.node",
		"native/darwin/prebuilds/**/*.node",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"tag": "beta"
	},
	"keywords": [
		"tui",
		"terminal",
		"ui",
		"text-editor",
		"differential-rendering",
		"typescript",
		"cli"
	],
	"contributors": [
		"Mario Zechner",
		"Jordan Hans"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hansjm10/Volt.git",
		"directory": "packages/tui"
	},
	"homepage": "https://github.com/hansjm10/Volt#readme",
	"bugs": {
		"url": "https://github.com/hansjm10/Volt/issues"
	},
	"license": "MIT",
	"engines": {
		"node": ">=22.19.0"
	},
	"types": "./dist/index.d.ts",
	"dependencies": {
		"get-east-asian-width": "1.6.0",
		"marked": "18.0.5"
	},
	"devDependencies": {
		"@xterm/headless": "5.5.0",
		"chalk": "5.6.2"
	}
}
