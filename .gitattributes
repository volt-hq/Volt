# Default to LF for text files across the repo
* text=auto eol=lf

# Windows scripts should keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell scripts should keep LF
*.sh text eol=lf

# Common binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary

# Preserve the exact upstream Node.js license bytes, including its original indentation.
compliance/node-v22.23.1/LICENSE -whitespace
